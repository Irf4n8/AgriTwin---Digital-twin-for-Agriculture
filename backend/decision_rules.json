      "reason": "High temperature detected with moderate moisture.",
      "benefit": "Mitigates heat stress.",
      "risk": "Medium",
      "priority": 2
    }
  ],
  "fertilizer": [
    {
      "condition": "growth_stage == 'Vegetative' and days_since_last_fert > 14",
      "action": "Apply Nitrogen Boost",
      "reason": "Vegetative stage requires high nitrogen.",
      "benefit": "Promotes leaf growth.",
      "risk": "Low",
      "priority": 3
    }
  ],
  "alerts": [
    {
      "condition": "rainfall_forecast > 50",
      "action": "Halt Irrigation",
      "reason": "Heavy rain forecast (>50mm).",
